# Copy to .env and edit for your bench, then:
#   uv run --env-file .env pytest --product m5stack-u001

# --- serial (pytest-embedded) ---
# Port env name = TEST_SERIAL_PORT_<PROFILE>, PROFILE = sketch.yaml profile
# uppercased with '-' -> '_'. Profile "esp32s3" -> TEST_SERIAL_PORT_ESP32S3.
TEST_SERIAL_PORT_ESP32S3=/dev/ttyACM0

# --- probe GPIO (injected as compile-time defines via build_config.toml) ---
TEST_I2C_SDA=8
TEST_I2C_SCL=9
TEST_UART_TX=3

# --- host / capture (sigrok) ---
SIGROK_DRIVER=fx2lafw
# conn (USB bus.device). Leave empty to let sigrok-cli pick its default.
SIGROK_CONN=
# Fixed 8MHz default (only affects .sr time precision; not stored, not hashed).
SIGROK_SAMPLERATE=8MHz
# Per-signal channel labels. Only the signals a probe needs are composed into
# the --channels argument at run time (no composite key in one variable).
SIGROK_CH_UART_TX=D0
SIGROK_CH_SCL=D1
SIGROK_CH_SDA=D2
# Optional: override the sigrok-cli binary (default: sigrok-cli on PATH).
# SIGROK_CLI=/usr/bin/sigrok-cli
